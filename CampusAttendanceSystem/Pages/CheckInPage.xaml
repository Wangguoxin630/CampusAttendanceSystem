<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CampusAttendanceSystem.Pages.CheckInPage"
             Title="Check In">

    <VerticalStackLayout Padding="30" Spacing="20">
        <Label Text="Current Time" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center"/>
        <Label x:Name="TimeLabel" FontSize="28" TextColor="Blue" HorizontalOptions="Center"/>

        <Button Text="Check In"
                BackgroundColor="#2ECC71" TextColor="White"
                FontSize="18" Clicked="OnCheckInClicked"/>

        <Button Text="Check Out"
                BackgroundColor="#E74C3C" TextColor="White"
                FontSize="18" Clicked="OnCheckOutClicked"/>

        <Button Text="View Records"
                BackgroundColor="#3498DB" TextColor="White"
                FontSize="18" Clicked="OnViewRecordsClicked"/>
    </VerticalStackLayout>

</ContentPage>