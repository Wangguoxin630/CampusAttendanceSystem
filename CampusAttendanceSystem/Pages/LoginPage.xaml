<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CampusAttendanceSystem.Pages.LoginPage"
             Title="Login">

    <VerticalStackLayout Padding="30" Spacing="20" BackgroundColor="{StaticResource Background}">
        <Label Text="Campus Attendance System" FontSize="26" HorizontalOptions="Center"/>
        <Entry x:Name="txtStudentId" Placeholder="Student ID"/>
        <Entry x:Name="txtPassword" Placeholder="Password" IsPassword="True"/>
        <Button Text="Sign In" Clicked="OnLoginClicked" BackgroundColor="{StaticResource Primary}" TextColor="White"/>
    </VerticalStackLayout>
</ContentPage>